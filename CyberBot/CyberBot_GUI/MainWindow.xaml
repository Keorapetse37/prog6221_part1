<Window x:Class="CyberBot_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Assistant" Height="600" Width="450"
        Loaded="Window_Loaded">
    <Grid Background="#F0F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Background="#1E293B" Padding="10">
            <TextBlock x:Name="AsciiHeader" FontFamily="Consolas" Foreground="#38BDF8" 
                       TextAlignment="Center" FontSize="12">
            </TextBlock>
        </Border>

        
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" Margin="10">
            <ListBox x:Name="ChatBox" Background="White" BorderThickness="0" 
                     FontFamily="Segoe UI" FontSize="14" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </ScrollViewer>

        
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox" Grid.Column="0" Padding="5" FontSize="14" 
                     KeyDown="InputBox_KeyDown" VerticalContentAlignment="Center"/>
            <Button x:Name="SendButton" Grid.Column="1" Content="Send" Width="80" Margin="10,0,0,0" 
                    Background="#0284C7" Foreground="White" Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>