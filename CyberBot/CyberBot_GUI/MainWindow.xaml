<Window x:Class="CyberBot_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Assistant" Height="600" Width="500"
        Loaded="Window_Loaded">
    <Grid Background="#F0F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ASCII header stays at the top, above the tabs -->
        <Border Grid.Row="0" Background="#1E293B" Padding="10">
            <TextBlock x:Name="AsciiHeader" FontFamily="Consolas" Foreground="#38BDF8"
                       TextAlignment="Center" FontSize="12"/>
        </Border>

        <TabControl Grid.Row="1" Margin="5" Background="White">

            <!-- ===== CHAT TAB ( existing UI) ===== -->
            <TabItem Header="Chat">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" x:Name="ChatScrollViewer" Margin="10">
                        <ListBox x:Name="ChatBox" Background="White" BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="14"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InputBox" Grid.Column="0" Padding="5" FontSize="14"
                                 KeyDown="InputBox_KeyDown" VerticalContentAlignment="Center"/>
                        <Button x:Name="SendButton" Grid.Column="1" Content="Send" Width="80"
                                Margin="10,0,0,0" Background="#0284C7" Foreground="White"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ===== TASKS TAB (new) ===== -->
            <TabItem Header="Tasks">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Cybersecurity Tasks" FontSize="18"
                               FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>

                    <!-- Input row for adding a task -->
                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,10">
                        <TextBox x:Name="TaskTitleBox" Padding="5" Margin="0,0,0,5"
                                 FontSize="13" Tag="Task title"/>
                        <TextBox x:Name="TaskDescBox" Padding="5" Margin="0,0,0,5"
                                 FontSize="13" Tag="Description"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Remind me in (days):" VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <TextBox x:Name="TaskReminderBox" Width="50" Padding="5" FontSize="13"/>
                            <Button x:Name="AddTaskButton" Content="Add Task" Width="90"
                                    Margin="15,0,0,0" Background="#0284C7" Foreground="White"
                                    Click="AddTaskButton_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- The task list -->
                    <ListView Grid.Row="2" x:Name="TaskListView" FontSize="13">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Done" Width="45"
                                    DisplayMemberBinding="{Binding IsCompleted}"/>
                                <GridViewColumn Header="Title" Width="160"
                                    DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="Description" Width="180"
                                    DisplayMemberBinding="{Binding Description}"/>
                                <GridViewColumn Header="Reminder" Width="100"
                                    DisplayMemberBinding="{Binding ReminderDate, StringFormat='yyyy-MM-dd'}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Action buttons for the selected task -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="CompleteTaskButton" Content="Mark Complete" Width="110"
                                Margin="0,0,10,0" Click="CompleteTaskButton_Click"/>
                        <Button x:Name="DeleteTaskButton" Content="Delete" Width="90"
                                Background="#DC2626" Foreground="White"
                                Click="DeleteTaskButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>